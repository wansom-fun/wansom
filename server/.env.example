# WANSOM Orchestrator Configuration Template
# COPY THIS FILE TO .env AND FILL IN THE PARAMETERS. DO NOT COMMIT .env SECRETS.

# Server configurations
PORT=4000
NODE_ENV=development

# Solana Cluster Connectivity
# Replace with a dedicated private RPC endpoint (e.g. Helius, Quicknode, Triton)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WSS_URL=wss://api.mainnet-beta.solana.com

# gRPC Geyser stream endpoints (optional, for low-latency ingest pipeline)
GEYSER_ENDPOINT_URL=
GEYSER_AUTH_HEADER=

# Keeper configurations for autonomous buyback-and-burn operations
# IMPORTANT: Keep the keypair filepath outside the source code repository directory.
KEEPER_KEYPAIR_PATH=/Users/user/.config/solana/id.json
KEEPER_TOKEN_MINT_ADDRESS=WAnSoMxY2tLm5wPQ8W2oB1zKzJn9q5Dk99A_MOCK

# Redis cache and queues
REDIS_URL=redis://localhost:6379

# PostgreSQL database URI (Prisma fallback: SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/wansom
